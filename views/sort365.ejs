<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="ie=edge" />
  <title>UNIQ Game - 365/366 Days Analysis Engine</title>

  <!-- SheetJS Library for Excel Parsing -->
  <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

  <!-- Custom Styles -->
  <link rel="stylesheet" href="/css/sort365.css">
</head>

<body>

  <!-- Top Navbar -->
  <nav class="navbar">
    <div class="brand-title">
      <span>UNIQ Game</span>
      <span class="brand-badge">365/366 Days Engine</span>
    </div>
    <div class="nav-actions">
      <a href="/logout" class="btn btn-warning">Logout</a>
    </div>
  </nav>

  <!-- Toolbar Controls -->
  <div class="toolbar">
    <div class="control-group">

      <div class="control-item">
        <label for="fileUpload">Excel File</label>
        <div class="file-input-wrapper">
          <label class="file-input-btn" for="fileUpload" id="fileNameLabel">📁 Choose Excel File</label>
          <input type="file" id="fileUpload" accept=".xlsx, .xls" />
        </div>
      </div>

      <div class="control-item">
        <label for="yearSelect">Select Year</label>
        <select id="yearSelect" class="select-input" disabled>
          <option value="">Upload Excel First</option>
        </select>
      </div>

      <div class="control-item">
        <label for="monthSelect">Select Month</label>
        <select id="monthSelect" class="select-input" disabled>
          <option value="ALL">All Months (Full Year)</option>
          <option value="Jan">Jan (January)</option>
          <option value="Feb">Feb (February)</option>
          <option value="Mar">Mar (March)</option>
          <option value="Apr">Apr (April)</option>
          <option value="May">May (May)</option>
          <option value="Jun">Jun (June)</option>
          <option value="Jul">Jul (July)</option>
          <option value="Aug">Aug (August)</option>
          <option value="Sep">Sep (September)</option>
          <option value="Oct">Oct (October)</option>
          <option value="Nov">Nov (November)</option>
          <option value="Dec">Dec (December)</option>
        </select>
      </div>

      <div class="control-item">
        <label for="startDateSelect">Start Date</label>
        <select id="startDateSelect" class="select-input" disabled>
          <option value="1">Date 1 (Default)</option>
          <option value="2">Date 2</option>
          <option value="3">Date 3</option>
          <option value="4">Date 4</option>
          <option value="5">Date 5</option>
          <option value="6">Date 6</option>
          <option value="7">Date 7</option>
          <option value="8">Date 8</option>
          <option value="9">Date 9</option>
          <option value="10">Date 10</option>
          <option value="11">Date 11</option>
          <option value="12">Date 12</option>
          <option value="13">Date 13</option>
          <option value="14">Date 14</option>
          <option value="15">Date 15</option>
          <option value="16">Date 16</option>
          <option value="17">Date 17</option>
          <option value="18">Date 18</option>
          <option value="19">Date 19</option>
          <option value="20">Date 20</option>
          <option value="21">Date 21</option>
          <option value="22">Date 22</option>
          <option value="23">Date 23</option>
          <option value="24">Date 24</option>
          <option value="25">Date 25</option>
          <option value="26">Date 26</option>
          <option value="27">Date 27</option>
          <option value="28">Date 28</option>
          <option value="29">Date 29</option>
          <option value="30">Date 30</option>
          <option value="31">Date 31</option>
        </select>
      </div>

      <div class="control-item">
        <label>Year Type</label>
        <div id="leapIndicator" class="leap-badge normal">
          <span>📅 Normal Year (365 Days)</span>
        </div>
      </div>

    </div>

    <div class="control-group">
      <button type="button" class="btn btn-warning" id="btnLoadPredict" disabled style="background-color: #f59e0b; color: white;">⚡ Load & Predict Winner</button>
      <button type="button" class="btn btn-primary" id="btnAddData" disabled style="background-color: #10b981; color: white;">➕ Import / Add Data</button>
      <button type="button" class="btn" id="btnSearch" disabled style="background-color: #ef4444; color: white;">🚀 Start Search (32 Sets)</button>
      <button type="button" class="btn btn-outline" id="btnReset">🔄 Reset Inputs</button>
    </div>
  </div>

  <!-- Host Secret Winner Alert Box (Revealed when Load is clicked) -->
  <div id="hostSecretBanner" style="display: none; background: linear-gradient(135deg, #1e1b4b, #312e81); border: 2px solid #818cf8; padding: 14px 24px; color: #fff; box-shadow: 0 4px 16px rgba(0,0,0,0.4);">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <div style="display: flex; align-items: center; gap: 12px;">
        <span style="font-size: 1.4rem;">🔑</span>
        <div>
          <div style="font-weight: 700; font-size: 0.95rem; color: #a5b4fc;">HOST GAME PRE-VIEW & NOTIFICATION DISPATCHED</div>
          <div id="hostSecretText" style="font-size: 0.9rem; font-weight: 600; color: #f8fafc; margin-top: 2px;">
            Pre-calculating winning set...
          </div>
        </div>
      </div>
      <button type="button" onclick="document.getElementById('hostSecretBanner').style.display='none'" style="background: transparent; border: 1px solid #818cf8; color: #a5b4fc; padding: 4px 10px; border-radius: 4px; cursor: pointer; font-size: 0.8rem;">Dismiss</button>
    </div>
  </div>

  <!-- Main Split Layout -->
  <div class="main-container" id="mainContainer">

    <!-- Left Panel: 365/366 Date Input Boxes -->
    <div class="left-panel" id="leftPanel">
      <div class="panel-header">
        <div style="display: flex; align-items: center; gap: 8px;">
          <span class="panel-title">📅 Date Input Entries</span>
          <span id="inputCountBadge" class="brand-badge">365 Days</span>
        </div>
        <button type="button" class="btn btn-outline" id="btnTogglePanel" title="Minimize / Expand Inputs Panel" style="padding: 2px 8px; font-size: 0.75rem;">◀ Collapse</button>
      </div>
      <div class="inputs-scroll-area" id="inputsScrollArea">
        <!-- Rendered dynamically by sort365.js -->
      </div>
    </div>

    <!-- Right Panel: Year Matrix Chart & Search Results -->
    <div class="right-panel">

      <!-- Winner Summary Header Banner -->
      <div id="winnerSummaryBanner" style="padding: 10px 16px; background-color: var(--panel-bg); border-bottom: 1px solid var(--panel-border); display: flex; align-items: center; justify-content: space-between;">
        <div style="display: flex; align-items: center; gap: 10px;">
          <span style="font-weight: 700; font-size: 0.9rem; color: var(--text-muted);">🏆 Winner Set Status:</span>
          <span id="winnerStatusBadge" class="brand-badge" style="background-color: #334155; color: #94a3b8;">Awaiting Search</span>
        </div>
        <div id="winnerDetailsText" style="font-size: 0.85rem; font-weight: 600; color: var(--text-main);">
          Click "Load & Predict Winner" or "Start Search" to evaluate 32 sets.
        </div>
      </div>

      <div class="tabs-bar">
        <button class="tab-btn active" id="tabBtnChart" onclick="switchTab('chart')">📊 Selected Year Matrix</button>
        <button class="tab-btn" id="tabBtnResults" onclick="switchTab('results')">🎯 Search Results (32 Sets)</button>
      </div>

      <!-- Tab 1: Excel Matrix View -->
      <div class="tab-content active" id="tabChart">
        <div class="matrix-container" id="matrixContainer">
          <p style="padding: 40px; text-align: center; color: var(--text-muted);">
            Please upload your Excel file and select a Year to view the interactive matrix chart.
          </p>
        </div>
      </div>

      <!-- Tab 2: Pattern Search Results -->
      <div class="tab-content" id="tabResults">
        <div id="resultsContainer">
          <p style="padding: 40px; text-align: center; color: var(--text-muted);">
            No search performed yet. Upload Excel, select year/month, click <b>➕ Import / Add Data</b>, and click <b>🚀 Start Search</b>.
          </p>
        </div>
      </div>
    </div>

  </div>

  <!-- Scripts -->
  <script src="/js/sort365.js"></script>
</body>

</html>
